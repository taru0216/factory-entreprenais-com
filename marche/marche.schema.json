{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://factory.entreprenais.com/marche/marche.schema.json",
  "title": "MarcheEvent",
  "description": "道のマルシェ カテゴリ SSOT スキーマ。AI・クローラーが生成・投入する機械処理フレンドリー設計。",
  "type": "object",
  "required": ["marche_id", "display_name", "region", "domain_slug", "hp_status"],
  "additionalProperties": true,
  "properties": {
    "marche_id": {
      "type": "string",
      "description": "マルシェ固有 ID（URL スラグと同値。小文字英数字・ハイフン）",
      "pattern": "^[a-z0-9-]+$"
    },
    "display_name": {
      "type": "string",
      "description": "表示名（例: 道のマルシェ白井）"
    },
    "region": {
      "type": "string",
      "description": "開催地域（例: 千葉県白井市）"
    },
    "domain_slug": {
      "type": "string",
      "description": "サブドメイン・URL 用スラグ（marche_id と基本同値）",
      "pattern": "^[a-z0-9-]+$"
    },
    "hp_status": {
      "type": "string",
      "enum": ["not_generated", "generated", "published", "archived"],
      "description": "HP 生成状態"
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "最終更新 ISO 8601 UTC"
    },
    "hero": {
      "type": "object",
      "description": "ヒーローセクション表示情報",
      "properties": {
        "catchphrase": { "type": "string", "description": "キャッチフレーズ（例: 白井の美味しいに、出会おう。）" },
        "image_url": { "type": "string", "description": "ヒーロー背景画像 URL" },
        "description": { "type": "string", "description": "ヒーロー説明文（1〜2文）" },
        "cta_label": { "type": "string", "description": "プライマリ CTA ボタンラベル" },
        "cta_href": { "type": "string", "description": "プライマリ CTA リンク先" },
        "cta_secondary_label": { "type": "string", "description": "サブ CTA ボタンラベル" },
        "cta_secondary_href": { "type": "string", "description": "サブ CTA リンク先" }
      }
    },
    "features": {
      "type": "object",
      "description": "機能フラグ",
      "properties": {
        "ai_assist": {
          "type": "boolean",
          "description": "AI アシスト機能の有無（出品者 AI 問い合わせ等）"
        }
      }
    },
    "highlights": {
      "type": "array",
      "description": "こんなものが集まります セクション（WHAT'S HERE）",
      "items": {
        "type": "object",
        "required": ["emoji", "title", "body"],
        "properties": {
          "emoji": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "image_url": { "type": "string" },
          "image_alt": { "type": "string" }
        }
      }
    },
    "enjoy_steps": {
      "type": "array",
      "description": "楽しみ方ステップ（HOW TO ENJOY）",
      "items": {
        "type": "object",
        "required": ["step", "title", "body"],
        "properties": {
          "step": { "type": "string", "description": "ステップ番号文字列（例: 01）" },
          "title": { "type": "string" },
          "body": { "type": "string" }
        }
      }
    },
    "voices": {
      "type": "array",
      "description": "来場者の声（VOICES）",
      "items": {
        "type": "object",
        "required": ["text", "from"],
        "properties": {
          "text": { "type": "string" },
          "from": { "type": "string", "description": "発話者属性（例: 30代 子育て中のお母さん）" }
        }
      }
    },
    "featured": {
      "type": "object",
      "description": "地域名産フィーチャーセクション（白井なら梨など、地域マルシェ内の名産コーナー）",
      "properties": {
        "enabled": { "type": "boolean" },
        "badge_text": { "type": "string" },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "image_url": { "type": "string" },
        "image_alt": { "type": "string" },
        "variety_tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "hashtags": {
      "type": "object",
      "description": "カテゴリ/旬LP のインデックス用 明示ハッシュタグ（migrate-marche-hashtags.py が付与）",
      "properties": {
        "categories": {
          "type": "array",
          "description": "食材カテゴリタグ（例: #梨 #いちご #野菜）",
          "items": { "type": "string" }
        },
        "months": {
          "type": "array",
          "description": "時期タグ（例: #8月 #9月）。四半期: 春=3-5月/夏=6-8月/秋=9-11月/冬=12-2月",
          "items": { "type": "string" }
        }
      }
    },
    "mood_items": {
      "type": "array",
      "description": "ムードセクション（気分を伝える3つのキーワード）",
      "items": {
        "type": "object",
        "required": ["label", "desc"],
        "properties": {
          "label": { "type": "string" },
          "desc": { "type": "string" }
        }
      }
    },
    "events": {
      "type": "array",
      "description": "開催予定イベント一覧",
      "items": {
        "type": "object",
        "properties": {
          "date": { "type": "string", "format": "date", "description": "開催日 YYYY-MM-DD" },
          "date_display": { "type": "string", "description": "表示用日付（例: 2026年7月19日（日））" },
          "location": { "type": "string" },
          "open_time": { "type": "string", "description": "開場時間（例: 10:00）" },
          "close_time": { "type": "string", "description": "終了時間（例: 15:00）" },
          "vendors": {
            "type": "array",
            "description": "出店者一覧",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "category": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "notify": {
      "type": "object",
      "description": "通知・SNS 連絡先",
      "properties": {
        "instagram_url": { "type": "string" },
        "line_url": { "type": "string" },
        "contact_email": { "type": "string" },
        "contact_note": { "type": "string" }
      }
    },
    "ambassador": {
      "type": "object",
      "description": "公式エージェント（AI アンバサダー）設定",
      "properties": {
        "link_map": { "type": "object", "additionalProperties": { "type": "string" } },
        "system_prompt_template": { "type": "string" },
        "port": { "type": "integer" }
      }
    },
    "i18n": {
      "type": "object",
      "description": "多言語フィールド",
      "properties": {
        "en": { "type": "object" },
        "zh": { "type": "object" },
        "ko": { "type": "object" }
      }
    },
    "ogp": {
      "type": "object",
      "description": "OGP / SNS シェア用メタ情報",
      "properties": {
        "image_url": {
          "type": "string",
          "description": "OGP 画像 URL（推奨サイズ: 1200×630px。Unsplash の場合 ?w=1200&h=630&fit=crop&q=80 を使用）"
        },
        "title": {
          "type": "string",
          "description": "OGP タイトル（og:title に使用。省略時は display_name を使用）"
        },
        "description": {
          "type": "string",
          "description": "OGP 説明文（og:description に使用。省略時は hero.description を使用）"
        }
      }
    },
    "farm_rentals": {
      "type": "object",
      "description": "農地貸しセクション。市民農園・田んぼオーナー制度・果樹園レンタルなど区画を借りて農作物を育てる体験農地を統一スキーマで管理。全国の自治体が特定農地貸付法・市民農園整備促進法に基づき運営。",
      "properties": {
        "title": {
          "type": "string",
          "description": "セクション見出し（例: 農地を借りて育てる体験）"
        },
        "description": {
          "type": "string",
          "description": "セクション説明文"
        },
        "items": {
          "type": "array",
          "description": "農地貸し施設一覧",
          "items": {
            "type": "object",
            "required": ["type", "name"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["community_garden", "paddy_owner", "orchard_rental", "other"],
                "description": "農地種別。community_garden=市民農園（畑区画）/ paddy_owner=田んぼオーナー制度（水田）/ orchard_rental=果樹園レンタル（果樹）/ other=その他"
              },
              "name": {
                "type": "string",
                "description": "農地・施設名"
              },
              "address": {
                "type": "string",
                "description": "所在地（住所または地区名）"
              },
              "land_type": {
                "type": "string",
                "enum": ["field", "paddy", "orchard", "mixed"],
                "description": "土地種別。field=畑 / paddy=水田 / orchard=果樹園 / mixed=混合。type と対応: community_garden→field, paddy_owner→paddy, orchard_rental→orchard が典型"
              },
              "plots": {
                "type": "integer",
                "description": "区画数（省略可。田んぼオーナー等で非公開の場合あり）"
              },
              "area_sqm": {
                "type": "number",
                "description": "1区画あたりの面積（㎡）。省略可"
              },
              "annual_fee_jpy": {
                "type": "integer",
                "description": "年間利用料（円）。省略可（非公開・要問合せの場合）"
              },
              "season": {
                "type": "string",
                "description": "利用シーズン（例: 4月〜翌3月、田植え〜稲刈り期間）。省略可"
              },
              "features": {
                "type": "array",
                "items": { "type": "string" },
                "description": "特徴タグ自由配列（例: 無農薬, 農具貸出, 指導付き, 体験型, 資材提供, 苗付き）"
              },
              "contact": {
                "type": "string",
                "description": "問い合わせ先（メールアドレスまたは電話番号）。省略可"
              },
              "url": {
                "type": "string",
                "description": "詳細情報 URL。省略可"
              }
            }
          }
        }
      }
    }
  }
}
